{
  "expo": {
    "name": "smart-expert-mental-support-system",
    "slug": "smart-expert-mental-support-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/image-2.png",
    "scheme": "smartexpertmentalsupportsystem",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.smartexpertmentalsupportsystem"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/image-2.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.smartexpertmentalsupportsystem",
      "usesCleartextTraffic": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/image-2.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mentally uses your location to sort nearby therapists."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/image-2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-mail-composer",
      "./plugins/withAsyncStorageRepo"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f913d40b-6605-4cd2-93a1-4e9f151b4f80"
      }
    }
  }
}
