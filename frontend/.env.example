# ============================================
# Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# Backend GraphQL endpoint (use your machine's LAN IP for physical device testing)
EXPO_PUBLIC_GRAPHQL_URL=http://192.168.x.x:8000/graphql/

# Google Gemini API key for AI chat assistant
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# OpenCage geocoding API key for location resolution (optional, falls back to "Kenya")
EXPO_PUBLIC_OPENCAGE_API_KEY=your_opencage_api_key_here

# Mobile app origin identifier
EXPO_PUBLIC_MOBILE_ORIGIN=smart-expert-system-for-mental-health-support
