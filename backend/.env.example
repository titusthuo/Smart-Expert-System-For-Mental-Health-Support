# ============================================
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Django Core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (comma-separated origins; leave empty to allow all in dev)
CORS_ALLOWED_ORIGINS=

# Database (leave empty to use SQLite for development)
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# Redis (leave empty to use InMemoryChannelLayer for development)
# REDIS_URL=redis://127.0.0.1:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# MAILTRAP_API_TOKEN=your-mailtrap-api-token
DEFAULT_FROM_EMAIL=noreply@smarthealth.com

# URLs
FRONTEND_URL=http://localhost:8081
BASE_URL=http://127.0.0.1:8000
